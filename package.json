{
  "name": "stealth-node",
  "version": "1.0.0",
  "description": "StealthNode — Professional-grade encrypted password & secrets manager for Windows",
  "author": "xylas007",
  "license": "MIT",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && electron-builder",
    "build:vite": "tsc -b && vite build",
    "preview": "vite preview",
    "electron:dev": "vite",
    "electron:build": "electron-builder"
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.2.0",
    "@codemirror/lang-html": "^6.4.0",
    "@codemirror/lang-javascript": "^6.2.0",
    "@codemirror/lang-json": "^6.0.0",
    "@codemirror/lang-markdown": "^6.2.0",
    "@codemirror/lang-python": "^6.1.0",
    "@codemirror/lang-sql": "^6.6.0",
    "@codemirror/state": "^6.4.0",
    "@codemirror/theme-one-dark": "^6.1.0",
    "@codemirror/view": "^6.28.0",
    "@tiptap/extension-color": "^2.5.0",
    "@tiptap/extension-highlight": "^2.27.2",
    "@tiptap/extension-link": "^2.27.2",
    "@tiptap/extension-text-style": "^2.5.0",
    "@tiptap/extension-underline": "^2.27.2",
    "@tiptap/pm": "^2.27.2",
    "@tiptap/react": "^2.27.2",
    "@tiptap/starter-kit": "^2.27.2",
    "electron-updater": "^6.2.1",
    "framer-motion": "^11.3.0",
    "hash-wasm": "^4.11.0",
    "lucide-react": "^0.408.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "three": "^0.184.0",
    "uuid": "^10.0.0",
    "zustand": "^4.5.4",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.184.1",
    "@types/uuid": "^10.0.0",
    "@types/zxcvbn": "^4.4.4",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.4",
    "vite": "^5.3.5",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "appId": "com.xylas007.stealthnode",
    "productName": "StealthNode",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/logo.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "StealthNode",
      "deleteAppDataOnUninstall": false
    },
    "files": [
      "dist-electron/**/*",
      "dist/**/*",
      "assets/**/*"
    ]
  }
}
