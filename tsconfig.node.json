{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "target": "ES2020",
    "outDir": "./dist-electron",
    "declaration": true,
    "declarationMap": true
  },
  "include": [
    "vite.config.ts",
    "src/main/**/*",
    "src/shared/**/*",
    "electron.d.ts"
  ]
}
